GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Telegram bot — optional
# Get token from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL where this server is reachable (e.g. ngrok or your VPS)
WEBHOOK_URL=

# Flight search — optional sources
# SerpAPI (Google Flights wrapper) — 100 free searches/month
# Get key at: https://serpapi.com/
SERPAPI_KEY=

# Skyscanner via RapidAPI — requires paid plan
# Get key at: https://rapidapi.com/skyscanner/api/skyscanner-flight-search
RAPIDAPI_KEY=
